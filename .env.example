# KájovoDagmar – example only. Never commit real values.
DAGMAR_PUBLIC_BASE_URL=https://dagmar.hcasc.cz
DAGMAR_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@127.0.0.1:5433/DBNAME
DAGMAR_SESSION_SECRET=replace-with-at-least-32-random-characters
DAGMAR_CSRF_SECRET=replace-with-at-least-32-random-characters

# Optional Google OpenID Connect. Keep disabled until the client and exact callback are registered.
DAGMAR_GOOGLE_OIDC_ENABLED=false
DAGMAR_GOOGLE_OIDC_CLIENT_ID=
DAGMAR_GOOGLE_OIDC_CLIENT_SECRET=
DAGMAR_GOOGLE_OIDC_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
DAGMAR_GOOGLE_OIDC_CALLBACK_URL=https://dagmar.hcasc.cz/api/v1/auth/google/callback

# Optional Sign in with Apple for web. The .p8 key must stay outside the repository.
DAGMAR_APPLE_SIGNIN_ENABLED=false
DAGMAR_APPLE_SERVICES_ID=
DAGMAR_APPLE_TEAM_ID=
DAGMAR_APPLE_KEY_ID=
DAGMAR_APPLE_PRIVATE_KEY_PATH=/etc/dagmar/secrets/apple-signin-key.p8
DAGMAR_APPLE_CALLBACK_URL=https://dagmar.hcasc.cz/api/v1/auth/apple/callback
DAGMAR_APPLE_ISSUER=https://appleid.apple.com
DAGMAR_APPLE_AUTHORIZATION_ENDPOINT=https://appleid.apple.com/auth/authorize
DAGMAR_APPLE_TOKEN_ENDPOINT=https://appleid.apple.com/auth/token
DAGMAR_APPLE_JWKS_ENDPOINT=https://appleid.apple.com/auth/keys

DAGMAR_EXTERNAL_AUTH_TRANSACTION_TTL_SECONDS=600
DAGMAR_EXTERNAL_AUTH_RESULT_TTL_SECONDS=120
DAGMAR_EXTERNAL_AUTH_HTTP_TIMEOUT_SECONDS=10
DAGMAR_EXTERNAL_AUTH_CLOCK_SKEW_SECONDS=30
